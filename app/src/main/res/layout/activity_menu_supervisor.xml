<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    tools:context=".MenuSupervisorActivity">

    <TextView
        android:id="@+id/txtTituloPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:text="PANEL DE SUPERVISOR"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <GridLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:columnCount="2"
        android:rowCount="3"
        app:layout_constraintTop_toBottomOf="@id/txtTituloPanel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            style="@style/TarjetaMenuSupervisor"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1">
            <LinearLayout style="@style/ContenedorBotonMenu">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/outline_accessibility_24" />
                <TextView
                    style="@style/TextoBotonMenu"
                    android:text="Gestión de\nUsuarios" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            style="@style/TarjetaMenuSupervisor"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1">
            <LinearLayout style="@style/ContenedorBotonMenu">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/outline_data_table_24" />
                <TextView
                    style="@style/TextoBotonMenu"
                    android:text="Gestor de\nDatos" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            style="@style/TarjetaMenuSupervisor"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1">
            <LinearLayout style="@style/ContenedorBotonMenu">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/outline_door_open_24" />
                <TextView
                    style="@style/TextoBotonMenu"
                    android:text="Accesos" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            style="@style/TarjetaMenuSupervisor"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1">
            <LinearLayout style="@style/ContenedorBotonMenu">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/outline_lock_24" />
                <TextView
                    style="@style/TextoBotonMenu"
                    android:text="Privilegios" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            style="@style/TarjetaMenuSupervisor"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1">
            <LinearLayout style="@style/ContenedorBotonMenu">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/outline_border_color_24" />
                <TextView
                    style="@style/TextoBotonMenu"
                    android:text="Personalizar" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            style="@style/TarjetaMenuSupervisor"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1">
            <LinearLayout style="@style/ContenedorBotonMenu">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/outline_handyman_24" />
                <TextView
                    style="@style/TextoBotonMenu"
                    android:text="Sistema" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </GridLayout>
</androidx.constraintlayout.widget.ConstraintLayout>